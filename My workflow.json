    {
      "parameters": {
        "jsCode": "// 1. 방금 저장한 뉴스 정보 (vulnerability_news 테이블 Insert 노드 결과)\nconst news = $node[\"Insert rows in a table\"].json;\n\n// 2. CMDB 전체 리스트 가져오기 (PostgreSQL 노드명 확인)\nconst cmdbData = $(\"Execute a SQL query\").all();\n\nlet alerts = [];\n\n// 3. 뉴스 속 target_service와 우리 CMDB 비교\nfor (const asset of cmdbData) {\n  const assetJson = asset.json;\n  const serviceName = (assetJson.service_name || \"\").toLowerCase();\n  const targetService = (news.target_service || \"\").toLowerCase();\n\n  // 서비스 이름 매칭 확인\n  if (targetService.includes(serviceName) || serviceName.includes(targetService)) {\n    alerts.push({\n      json: {\n        is_matched: true,\n        asset_id: assetJson.id,\n        news_id: news.id,\n        alert_level: news.severity,\n        asset_name: assetJson.asset_name,\n        service_info: `${assetJson.service_name} (v${assetJson.service_version})`,\n        news_title: news.title,\n        cve_id: news.cve_id,\n        target_version: news.target_version // 필요시 AI 추출 데이터에 포함\n      }\n    });\n  }\n}\n\n// 4. 매칭된 결과가 있을 때만 해당 리스트 반환, 없으면 false 상태 전송\nreturn alerts.length > 0 ? alerts : [{ json: { is_matched: false } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
