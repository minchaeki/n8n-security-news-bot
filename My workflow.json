      "parameters": {
        "jsCode": "const outputText = $json.output || \"\";\nconst jsonMatch = outputText.match(/\\{[\\s\\S]*\\}/);\n\nif (!jsonMatch) {\n    throw new Error(\"AI 응답에서 JSON 형식을 찾을 수 없습니다.\");\n}\n\nconst aiResult = JSON.parse(jsonMatch[0]);\n\n// 에러 방지를 위해 노드 데이터를 변수에 먼저 담습니다.\n// 노드 이름이 'Filter'인지 'Filter1'인지 확인 후 아래 이름을 수정하세요.\nconst originalData = $(\"Filter\").first().json; \n\nreturn {\n  ...aiResult,\n  original_title: originalData[\"title\"],\n  link: originalData[\"link\"],\n  pubDate: originalData[\"pubDate\"]\n};"
      },
