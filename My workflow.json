    {
      "parameters": {
        "jsCode": "// 1. 모든 데이터 가져오기\nconst allItems = items;\nlet boan = [], daily = [], kisa = [], hackers = [], bleeping = [];\n\n// [특수 로직] 보안뉴스 전용 한글 복구 함수\nfunction fixBoanTitle(text) {\n    if (!text) return \"제목 없음\";\n    // 보안뉴스 특유의 깨진 유니코드 패턴을 한글/숫자/영문만 남기고 정제\n    return String(text)\n        .replace(/[^\\uAC00-\\uD7AF\\u1100-\\u11FF\\u3130-\\u318F\\u0020-\\u007E]/g, \"\") \n        .replace(/\\s+/g, ' ') // 중복 공백 제거\n        .trim();\n}\n\n// 2. 분류 및 제목 교정\nallItems.forEach(item => {\n    let rawTitle = item.json.title || \"제목 없음\";\n    const link = (item.json.link || \"\").toLowerCase();\n    \n    // 보안뉴스라면 제목 복구 로직 가동\n    let cleanTitle = link.includes('boannews') ? fixBoanTitle(rawTitle) : rawTitle;\n\n    const data = { title: cleanTitle, link: item.json.link };\n\n    if (link.includes('boannews')) boan.push({ ...data, tag: '[보안뉴스]', color: '#d32f2f' });\n    else if (link.includes('dailysecu')) daily.push({ ...data, tag: '[데일리시큐]', color: '#1a73e8' });\n    else if (link.includes('krcert') || link.includes('knvd')) kisa.push({ ...data, tag: '[KISA]', color: '#2e7d32' });\n    else if (link.includes('thehackernews')) hackers.push({ ...data, tag: '[TheHackerNews]', color: '#f57c00' });\n    else if (link.includes('bleepingcomputer')) bleeping.push({ ...data, tag: '[BleepingComp]', color: '#455a64' });\n});\n\n// 3. 골고루 7개씩 추출 및 믹스\nconst finalSelection = [\n    ...boan.slice(0, 7),\n    ...daily.slice(0, 7),\n    ...kisa.slice(0, 7),\n    ...hackers.slice(0, 7),\n    ...bleeping.slice(0, 7)\n];\nfinalSelection.sort(() => 0.5 - Math.random());\n\n// 4. HTML 생성\nlet html = `<div style=\"font-family: 'Malgun Gothic', sans-serif; padding: 20px; background-color: #f4f7f9;\">\n    <h2 style=\"color: #333; border-bottom: 3px solid #d32f2f; padding-bottom: 10px;\">🛡️ 통합 보안 뉴스레터</h2>`;\n\nfinalSelection.forEach(n => {\n    html += `\n    <div style=\"background: white; padding: 15px; margin-bottom: 10px; border-radius: 8px; border-left: 5px solid ${n.color};\">\n        <span style=\"color: ${n.color}; font-weight: bold; font-size: 11px;\">${n.tag}</span><br>\n        <a href=\"${n.link}\" target=\"_blank\" style=\"text-decoration: none; color: #333; font-weight: bold; font-size: 15px;\">${n.title}</a>\n    </div>`;\n});\n\nreturn [{ json: { html_report: html + \"</div>\" } }];"
      },
